# ─── CHIN Server Environment Variables ───────────────────
# Copy this file to .env and adjust values.

# Port the server listens on (Render/Railway set this automatically)
PORT=3000

# Frontend URL for CORS (use * to allow all origins, or specify your Netlify/Vercel URL)
# Examples:
#   CORS_ORIGIN=*
#   CORS_ORIGIN=https://chin-game.netlify.app
#   CORS_ORIGIN=https://chin-game.vercel.app
CORS_ORIGIN=*
