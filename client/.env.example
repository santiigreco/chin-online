# ─── CHIN Client Environment Variables ───────────────────
# Copy this file to .env and adjust values.
# All Vite env vars must start with VITE_ to be accessible in the browser.

# URL of the backend server
# For local development:
#   VITE_SERVER_URL=http://localhost:3000
# For production (replace with your Render/Railway URL):
#   VITE_SERVER_URL=https://chin-server.onrender.com
VITE_SERVER_URL=http://localhost:3000
